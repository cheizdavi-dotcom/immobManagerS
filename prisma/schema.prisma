// This is your Prisma schema file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// --- NextAuth Models ---
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("ADMIN") // ADMIN, MANAGER, BROKER
  accounts      Account[]
  sessions      Session[]
  
  // CRM Relations
  sales         Sale[]    @relation("UserSales")
  visits        Visit[]   @relation("UserVisits")
  clients       Client[]  @relation("UserClients")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- CRM Models ---
model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  cpf       String?  @unique
  status    String   @default("Morno")
  kanbanPhase String @default("NOVO") // NOVO, CONTATO, AGENDADO, NEGOCIACAO, CONTRATO, FECHADO
  contractUrl String?
  ultimoContato DateTime? // Data do Ãºltimo contato (visita, mensagem, etc)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String?
  user      User?     @relation("UserClients", fields: [userId], references: [id])
  
  sales     Sale[]
  visits    Visit[]
}

model Broker {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  creci     String?  @unique
  avatar    String?  // Base64 or URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  sales     Sale[]
  visits    Visit[]
}

model Development {
  id        String   @id @default(cuid())
  name      String
  builder   String   // Construtora
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  sales     Sale[]
  properties Property[]
  visits    Visit[]
}

model Sale {
  id              String      @id @default(cuid())
  amount          Float
  commissionRate  Float       // e.g., 5.0 for 5%
  commissionValue Float       // Calculated value
  status          String      @default("PROSPECT") // PROSPECT, CREDIT_ANALYSIS, SIGNATURE, WON, LOST
  isPaid          Boolean     @default(false)
  paidAt          DateTime?
  downPayment     Float       @default(0)
  notes           String?
  nextStep        String?
  nextStepDate    DateTime?      // If commission has been paid
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id])
  
  brokerId        String
  broker          Broker      @relation(fields: [brokerId], references: [id])
  
  developmentId   String
  development     Development @relation(fields: [developmentId], references: [id])
  
  propertyId      String?
  property        Property?   @relation(fields: [propertyId], references: [id])
  
  userId          String
  user            User        @relation("UserSales", fields: [userId], references: [id])
}

// --- GLOBALS ---
model GlobalSettings {
  id               String   @id @default("singleton")
  companyName      String   @default("ImmobManager Hub")
  cnpj             String   @default("")
  houseCommission  Float    @default(40.0)
  brokerCommission Float    @default(60.0)
  whatsappActive   Boolean  @default(false)
  whatsappToken    String?
  metaActive       Boolean  @default(false)
  metaPixelId      String?
  rdStationActive  Boolean  @default(false)
  rdStationToken   String?
  alertNewLead     Boolean  @default(true)
  alertSignature   Boolean  @default(true)
  alertDefault     Boolean  @default(false)
  alertLost        Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

// --- IMÃ“VEIS & VISITAS ---
model Property {
  id            String   @id @default(cuid())
  title         String
  type          String   // APARTAMENTO, CASA, TERRENO, SALA_COMERCIAL, LOJA, SOBRADO, CHACARA
  address       String
  neighborhood  String?
  city          String?
  state         String   @default("SP")
  area          Float?
  bedrooms      Int      @default(0)
  bathrooms     Int      @default(0)
  parkingSpaces Int      @default(0)
  price         Float?
  status        String   @default("DISPONIVEL") // DISPONIVEL, RESERVADO, VENDIDO
  photos        String?  // JSON array de URLs
  
  developmentId String?
  development   Development? @relation(fields: [developmentId], references: [id])
  
  visits        Visit[]
  sales         Sale[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Visit {
  id          String   @id @default(cuid())
  scheduledAt DateTime
  duration    Int      @default(30) // minutos
  status      String   @default("AGENDADA") // AGENDADA, CONFIRMADA, REALIZADA, CANCELADA, REMARCADA
  notes       String?
  feedback    String?
  rating      Int?
  
  developmentId String?
  development   Development? @relation(fields: [developmentId], references: [id])
  
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  
  brokerId    String
  broker      Broker   @relation(fields: [brokerId], references: [id])
  
  userId      String
  user        User     @relation("UserVisits", fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}




